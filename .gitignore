# Temp and local
temp/
*.log
.env
.env.local
*.local

# OpenSpec / reports (опционально: раскомментируйте, если не хранить отчёты в репо)
# openspec/changes/*/reports/
# temp/reports/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE / Cursor (если не хотите коммитить настройки сессий)
# .cursor/workspaceStorage/

# 1C / Vanessa (если появятся)
# *.epf
