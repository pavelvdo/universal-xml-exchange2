# out/

# Конфигурации 1С (.cf) не храним в Git (особенно под src — тяжёлые ParentConfigurations).
*.cf
src/**/*.cf
/archive1c/

# Выгрузка базовой конфигурации (XML dump) — не храним в Git
**/cf/

