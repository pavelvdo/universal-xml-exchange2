#Область ОбработчикиСобытийФормы

// ВдовинПЮ: Подсистема универсального обмена XML между ИБ 1С через веб-сервис и правила в макетах +++
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ПарольИзменен = Ложь;
	
	Если НЕ Объект.Ссылка.Пустая() Тогда
		ПрочитатьПароль();
	КонецЕсли;
	
	Расписание = ПолучитьРасписаниеИзОбъектаИлиЗадания();
	ПравилаОбменаДанными = ПолучитьПравилаОбменаИзОбъекта();
	
	// +++ Вдовин П.Ю. 29.06.2026 Двухфазный обмен XML: статусы профиля, GetData, ConfirmDataReceipt, правила в хранилище
	рг_УниверсальныйОбменXMLСервер.ЗаполнитьСписокСтатусов(СписокСтатусов);
	УстановитьВидимостьГруппПоРоли();
	ОбновитьИндикаторПравилЗагружены();
	// --- Вдовин П.Ю.
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ПарольДействительноИзменен = ПарольИзменен И Пароль <> Строка(УникальныйИдентификатор);
	ТекущийОбъект.ДополнительныеСвойства.Вставить("ПарольИзменен", ПарольДействительноИзменен);
	
	Если ПарольДействительноИзменен Тогда
		ТекущийОбъект.ДополнительныеСвойства.Вставить("Пароль", Пароль);
	КонецЕсли;
	
	ТекущийОбъект.Расписание = Новый ХранилищеЗначения(Расписание);
	ТекущийОбъект.ДополнительныеСвойства.Вставить("Расписание", Расписание);
	ТекущийОбъект.ПравилаОбменаДанными = ПравилаОбменаДанными;
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ОбновитьОтображениеПароляПослеЗаписи();
	
КонецПроцедуры
