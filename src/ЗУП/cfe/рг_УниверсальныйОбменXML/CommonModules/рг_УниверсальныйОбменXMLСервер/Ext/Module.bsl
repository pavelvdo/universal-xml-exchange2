// Возвращает UX-подпись для кода статуса профиля-источника.

//

// Параметры:

//   Код - Строка - код статуса (см. функции Статус*()).

//

// Возвращаемое значение:

//   Строка - подпись для отображения пользователю.

//

Функция ПредставлениеСтатуса(Код) Экспорт

	

	Если Код = СтатусНеГотов() Тогда

		Возврат НСтр("ru = 'Не готов к обмену'");

	ИначеЕсли Код = СтатусНовое() Тогда

		Возврат НСтр("ru = 'Готов к обмену'");

	ИначеЕсли Код = СтатусВыполняется() Тогда

		Возврат НСтр("ru = 'Идёт обмен'");

	ИначеЕсли Код = СтатусВыполнено() Тогда

		Возврат НСтр("ru = 'Обмен завершён'");

	ИначеЕсли Код = СтатусОшибка() Тогда

		Возврат НСтр("ru = 'Ошибка обмена'");

	КонецЕсли;

	

	ВызватьИсключение СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(

		НСтр("ru = 'Неизвестный код статуса обмена: ""%1"".'"),

		Код);

	

КонецФункции



// Наполняет список значений парами код — подпись статуса.

//

// Параметры:

//   СписокЗначений - СписокЗначений - список для наполнения.

//

Процедура ЗаполнитьСписокСтатусов(СписокЗначений) Экспорт

	

	СписокЗначений.Очистить();

	СписокЗначений.Добавить(СтатусНеГотов(), ПредставлениеСтатуса(СтатусНеГотов()));

	СписокЗначений.Добавить(СтатусНовое(), ПредставлениеСтатуса(СтатусНовое()));

	СписокЗначений.Добавить(СтатусВыполняется(), ПредставлениеСтатуса(СтатусВыполняется()));

	СписокЗначений.Добавить(СтатусВыполнено(), ПредставлениеСтатуса(СтатусВыполнено()));

	СписокЗначений.Добавить(СтатусОшибка(), ПредставлениеСтатуса(СтатусОшибка()));

	

КонецПроцедуры



