Процедура ЗаписатьСобытиеОбмена(Уровень, Профиль = Неопределено, ТекстСообщения = "")

	

	ЗаписьЖурналаРегистрации(

		"рг.УниверсальныйОбменXML",

		Уровень,

		Метаданные.Справочники.рг_НастройкиОбменаXML,

		Профиль,

		ТекстСообщения);

	

КонецПроцедуры



// Записывает объект профиля-источника после изменения только реквизита Статус.

//

// Параметры:

//   ОбъектПрофиля - СправочникОбъект.рг_НастройкиОбменаXML - объект профиля с установленным Статус.

//

Процедура ЗаписатьСтатусПрофиляИсточника(ОбъектПрофиля)

	

	УстановитьПривилегированныйРежим(Истина);

	

	Попытка

		

		ОбъектПрофиля.ОбменДанными.Загрузка = Истина;

		ОбъектПрофиля.Записать();

		

	Исключение

		

		УстановитьПривилегированныйРежим(Ложь);

		ВызватьИсключение;

		

	КонецПопытки;

	

	УстановитьПривилегированныйРежим(Ложь);

	

КонецПроцедуры



Процедура НачатьВыгрузкуGetData(ПрофильИсточника)

	

	НачатьТранзакцию();

	

	Попытка

		

		Блокировка = Новый БлокировкаДанных;

		ЭлементБлокировки = Блокировка.Добавить("Справочник.рг_НастройкиОбменаXML");

		ЭлементБлокировки.УстановитьЗначение("Ссылка", ПрофильИсточника);

		Блокировка.Заблокировать();

		

		ОбъектПрофиля = ПрофильИсточника.ПолучитьОбъект();

		

		Если ОбъектПрофиля.Статус <> Перечисления.рг_СтатусыОбмена.Новое Тогда

			

			ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(

				НСтр("ru = 'Выгрузка данных недоступна: профиль в статусе ""%1"", требуется ""%2"".'"),

				ОбъектПрофиля.Статус,

				Перечисления.рг_СтатусыОбмена.Новое);

			ЗаписатьСобытиеОбмена(УровеньЖурналаРегистрации.Ошибка, ПрофильИсточника, ТекстОшибки);

			ВызватьИсключение ТекстОшибки;

			

		КонецЕсли;

		

		ОбъектПрофиля.Статус = Перечисления.рг_СтатусыОбмена.Выполняется;

		ЗаписатьСтатусПрофиляИсточника(ОбъектПрофиля);

		

		ЗаписатьСобытиеОбмена(

			УровеньЖурналаРегистрации.Информация,

			ПрофильИсточника,

			НСтр("ru = 'Статус профиля изменён: Новое → Выполняется'"));

		

		ЗафиксироватьТранзакцию();

		

	Исключение

		

		ОтменитьТранзакцию();

		ВызватьИсключение;

		

	КонецПопытки;

	

КонецПроцедуры



Процедура УстановитьСтатусПрофиляИсточника(ПрофильИсточника, НовыйСтатус, ТекстСообщения = "")

	

	НачатьТранзакцию();

	

	Попытка

		

		Блокировка = Новый БлокировкаДанных;

		ЭлементБлокировки = Блокировка.Добавить("Справочник.рг_НастройкиОбменаXML");

		ЭлементБлокировки.УстановитьЗначение("Ссылка", ПрофильИсточника);

		Блокировка.Заблокировать();

		

		ОбъектПрофиля = ПрофильИсточника.ПолучитьОбъект();

		ПредыдущийСтатус = ОбъектПрофиля.Статус;

		ОбъектПрофиля.Статус = НовыйСтатус;

		ЗаписатьСтатусПрофиляИсточника(ОбъектПрофиля);

		

		Если ПустаяСтрока(ТекстСообщения) Тогда

			ТекстЖурнала = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(

				НСтр("ru = 'Статус профиля изменён: %1 → %2'"),

				ПредыдущийСтатус,

				НовыйСтатус);

		Иначе

			ТекстЖурнала = ТекстСообщения;

		КонецЕсли;

		

		ЗаписатьСобытиеОбмена(УровеньЖурналаРегистрации.Информация, ПрофильИсточника, ТекстЖурнала);

		

		ЗафиксироватьТранзакцию();

		

	Исключение

		

		ОтменитьТранзакцию();

		ВызватьИсключение;

		

	КонецПопытки;

	

КонецПроцедуры



Функция ВыполнитьФазуВыгрузкиGetData(ПрофильИсточника)

	

	ИменаФайловВыгрузки = Неопределено;

	

	Попытка

		

		ИменаФайловВыгрузки = ВыгрузитьДанныеДвижком(ПрофильИсточника);

		ДвоичныеДанныеZip = УпаковатьВыгрузкуВZip(

			ИменаФайловВыгрузки.ИмяФайлаПравил,

			ИменаФайловВыгрузки.ИмяФайлаДанных);

		

	Исключение

		

		Если ИменаФайловВыгрузки <> Неопределено Тогда

			УдалитьВременныеФайлыИКаталоги(ИменаФайловВыгрузки.ВременныеПути);

		КонецЕсли;

		ВызватьИсключение;

		

	КонецПопытки;

	

	УдалитьВременныеФайлыИКаталоги(ИменаФайловВыгрузки.ВременныеПути);

	

	Возврат ДвоичныеДанныеZip;

	

КонецФункции



Функция ВыгрузитьДанныеДвижком(ПрофильИсточника)

	

	РеквизитыПрофиля = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(

		ПрофильИсточника,

		"ПравилаОбменаДанными");

	

	ИмяФайлаПравил = ЗаписатьПравилаОбменаВоВременныйФайл(РеквизитыПрофиля.ПравилаОбменаДанными);

	ИмяФайлаДанных = ПолучитьИмяВременногоФайла("xml");

	

	ВременныеПути = Новый Массив;

	ВременныеПути.Добавить(ИмяФайлаПравил);

	ВременныеПути.Добавить(ИмяФайлаДанных);

	

	Движок = Обработки.рг_УниверсальныйОбменДаннымиXML.Создать();

	Движок.ИмяФайлаПравилОбмена = ИмяФайлаПравил;

	Движок.ЗагрузитьПравилаОбмена();

	Движок.ИнициализироватьПервоначальныеЗначенияПараметров();

	

	ПараметрыПрофиля = ПараметрыПрофиляИсточника(ПрофильИсточника);

	

	Для Каждого СтрокаПараметра Из ПараметрыПрофиля Цикл

		Движок.УстановитьЗначениеПараметраВТаблице(

			СтрокаПараметра.ИмяПараметра,

			СтрокаПараметра.ЗначениеПараметра);

	КонецЦикла;

	

	Движок.ИмяФайлаОбмена = ИмяФайлаДанных;

	Движок.ВыполнитьВыгрузку();

	

	Если Движок.ФлагОшибки Тогда

		УдалитьВременныеФайлыИКаталоги(ВременныеПути);

		ВызватьИсключение НСтр("ru = 'Движок обмена завершил выгрузку с ошибками.'");

	КонецЕсли;

	

	ФайлДанных = Новый Файл(ИмяФайлаДанных);

	

	Если НЕ ФайлДанных.Существует() ИЛИ ФайлДанных.Размер() = 0 Тогда

		ВызватьИсключение НСтр("ru = 'Движок обмена не сформировал файл данных выгрузки.'");

	КонецЕсли;

	

	Результат = Новый Структура;

	Результат.Вставить("ИмяФайлаПравил", ИмяФайлаПравил);

	Результат.Вставить("ИмяФайлаДанных", ИмяФайлаДанных);

	Результат.Вставить("ВременныеПути", ВременныеПути);

	

	Возврат Результат;

	

КонецФункции



Функция ПараметрыПрофиляИсточника(ПрофильИсточника)

	

	Запрос = Новый Запрос;

	Запрос.Текст =

	"ВЫБРАТЬ

	|	Параметры.ИмяПараметра КАК ИмяПараметра,

	|	Параметры.ЗначениеПараметра КАК ЗначениеПараметра

	|ИЗ

	|	Справочник.рг_НастройкиОбменаXML.Параметры КАК Параметры

	|ГДЕ

	|	Параметры.Ссылка = &Профиль";

	

	Запрос.УстановитьПараметр("Профиль", ПрофильИсточника);

	

	Возврат Запрос.Выполнить().Выгрузить();

	

КонецФункции



Функция ЗаписатьПравилаОбменаВоВременныйФайл(ПравилаОбменаДанными)

	

	Если НЕ ЗначениеЗаполнено(ПравилаОбменаДанными) Тогда

		ВызватьИсключение НСтр("ru = 'В профиле-источнике не заданы правила обмена.'");

	КонецЕсли;

	

	СодержимоеПравил = ПравилаОбменаДанными.Получить();

	ИмяФайлаПравил = ПолучитьИмяВременногоФайла("xml");

	

	Если ТипЗнч(СодержимоеПравил) = Тип("Строка") Тогда

		

		ЗаписьТекста = Новый ЗаписьТекста(ИмяФайлаПравил, КодировкаТекста.UTF8);

		ЗаписьТекста.Записать(СодержимоеПравил);

		ЗаписьТекста.Закрыть();

		

	ИначеЕсли ТипЗнч(СодержимоеПравил) = Тип("ДвоичныеДанные") Тогда

		

		СодержимоеПравил.Записать(ИмяФайлаПравил);

		

	Иначе

		

		ВызватьИсключение НСтр("ru = 'Неподдерживаемый формат правил обмена в хранилище профиля.'");

		

	КонецЕсли;

	

	Возврат ИмяФайлаПравил;

	

КонецФункции



Функция УпаковатьВыгрузкуВZip(ИмяФайлаПравил, ИмяФайлаДанных)

	

	КаталогАрхива = ПолучитьИмяВременногоФайла("");

	СоздатьКаталог(КаталогАрхива);

	

	ИмяПравилВКаталоге = ОбщегоНазначенияКлиентСервер.ДобавитьКонецРазделителяПути(КаталогАрхива)

		+ ИмяФайлаПравилВАрхиве();

	ИмяДанныхВКаталоге = ОбщегоНазначенияКлиентСервер.ДобавитьКонецРазделителяПути(КаталогАрхива)

		+ ИмяФайлаДанныхВАрхиве();

	

	КопироватьФайл(ИмяФайлаПравил, ИмяПравилВКаталоге);

	КопироватьФайл(ИмяФайлаДанных, ИмяДанныхВКаталоге);

	

	ИмяZip = ПолучитьИмяВременногоФайла("zip");

	МаскаФайлов = ОбщегоНазначенияКлиентСервер.ДобавитьКонецРазделителяПути(КаталогАрхива) + "*.xml";

	

	Если НЕ ОбменДаннымиСервер.ЗапаковатьВZipФайл(ИмяZip, МаскаФайлов) Тогда

		УдалитьВременныеФайлыИКаталоги(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(КаталогАрхива));

		ВызватьИсключение НСтр("ru = 'Не удалось упаковать файлы выгрузки в ZIP-архив.'");

	КонецЕсли;

	

	ДвоичныеДанныеZip = Новый ДвоичныеДанные(ИмяZip);

	УдалитьФайлы(ИмяZip);

	УдалитьФайлы(КаталогАрхива);

	

	Возврат ДвоичныеДанныеZip;

	

КонецФункции



Функция ПодготовитьДанныеСеансаПриемника(ПрофильПриемника)

	

	РеквизитыПрофиля = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(

		ПрофильПриемника,

		"АдресСервиса, Логин, Префикс, ПрефиксБазыПриемника, Источник");

	

	Если РеквизитыПрофиля.Источник Тогда

		ВызватьИсключение НСтр("ru = 'Сеанс обмена на приёмнике доступен только для профиля с ролью приёмника.'");

	КонецЕсли;

	

	УстановитьПривилегированныйРежим(Истина);

	Пароль = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(ПрофильПриемника, "Пароль");

	УстановитьПривилегированныйРежим(Ложь);

	

	ДанныеСеансаОбмена = Новый Структура;

	ДанныеСеансаОбмена.Вставить("ПрофильПриемника", ПрофильПриемника);

	ДанныеСеансаОбмена.Вставить("АдресСервиса", РеквизитыПрофиля.АдресСервиса);

	ДанныеСеансаОбмена.Вставить("Логин", РеквизитыПрофиля.Логин);

	ДанныеСеансаОбмена.Вставить("Пароль", Пароль);

	ДанныеСеансаОбмена.Вставить("Префикс", РеквизитыПрофиля.Префикс);

	ДанныеСеансаОбмена.Вставить("ПрефиксБазыПриемника", РеквизитыПрофиля.ПрефиксБазыПриемника);

	

	Возврат ДанныеСеансаОбмена;

	

КонецФункции



Функция ВызватьGetDataНаИсточнике(ДанныеСеансаОбмена)

	

	Прокси = СоздатьПроксиОбмена(ДанныеСеансаОбмена);

	

	Попытка

		

		Возврат Прокси.GetData(ДанныеСеансаОбмена.Префикс, ДанныеСеансаОбмена.ПрефиксБазыПриемника);

		

	Исключение

		

		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());

		ЗаписатьСобытиеОбмена(

			УровеньЖурналаРегистрации.Ошибка,

			ДанныеСеансаОбмена.ПрофильПриемника,

			ТекстОшибки);

		ВызватьИсключение;

		

	КонецПопытки;

	

КонецФункции



Процедура ВызватьConfirmDataReceiptНаИсточнике(ДанныеСеансаОбмена)

	

	Прокси = СоздатьПроксиОбмена(ДанныеСеансаОбмена);

	

	Попытка

		

		Прокси.ConfirmDataReceipt(ДанныеСеансаОбмена.Префикс, ДанныеСеансаОбмена.ПрефиксБазыПриемника);

		

	Исключение

		

		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());

		ЗаписатьСобытиеОбмена(

			УровеньЖурналаРегистрации.Ошибка,

			ДанныеСеансаОбмена.ПрофильПриемника,

			ТекстОшибки);

		ВызватьИсключение;

		

	КонецПопытки;

	

КонецПроцедуры



Функция СоздатьПроксиОбмена(ДанныеСеансаОбмена)

	

	ПараметрыПодключения = ОбщегоНазначения.ПараметрыПодключенияWSПрокси();

	ПараметрыПодключения.АдресWSDL = АдресWSDLСервисаОбмена(ДанныеСеансаОбмена.АдресСервиса);

	ПараметрыПодключения.URIПространстваИмен = URIПространстваИменСервисаОбмена();

	ПараметрыПодключения.ИмяСервиса = ИмяСервисаОбмена();

	ПараметрыПодключения.ИмяПользователя = ДанныеСеансаОбмена.Логин;

	ПараметрыПодключения.Пароль = ДанныеСеансаОбмена.Пароль;

	ПараметрыПодключения.Местоположение = МестоположениеСервисаОбмена(ДанныеСеансаОбмена.АдресСервиса);

	ПараметрыПодключения.Таймаут = 600;

	

	Возврат ОбщегоНазначения.СоздатьWSПрокси(ПараметрыПодключения);

	

КонецФункции



Функция АдресWSDLСервисаОбмена(АдресСервиса)

	

	БазовыйАдрес = СокрЛП(АдресСервиса);

	

	Если СтрЗаканчиваетсяНа(НРег(БазовыйАдрес), "?wsdl") Тогда

		Возврат БазовыйАдрес;

	КонецЕсли;

	

	Если СтрЗаканчиваетсяНа(НРег(БазовыйАдрес), ".1cws") Тогда

		Возврат БазовыйАдрес + "?wsdl";

	КонецЕсли;

	

	Возврат ОбщегоНазначенияКлиентСервер.ДобавитьКонецРазделителяПути(БазовыйАдрес)

		+ "ws/" + ИмяСервисаОбмена() + "?wsdl";

	

КонецФункции



Функция МестоположениеСервисаОбмена(АдресСервиса)

	

	БазовыйАдрес = СокрЛП(АдресСервиса);

	

	Если СтрЗаканчиваетсяНа(НРег(БазовыйАдрес), "?wsdl") Тогда

		Возврат Лев(БазовыйАдрес, СтрДлина(БазовыйАдрес) - СтрДлина("?wsdl"));

	КонецЕсли;

	

	Если СтрЗаканчиваетсяНа(НРег(БазовыйАдрес), ".1cws") Тогда

		Возврат БазовыйАдрес;

	КонецЕсли;

	

	Возврат ОбщегоНазначенияКлиентСервер.ДобавитьКонецРазделителяПути(БазовыйАдрес)

		+ "ws/" + ИмяСервисаОбмена();

	

КонецФункции



Процедура ЗагрузитьДанныеИзАрхива(АрхивДанных)

	

	ИмяZip = ПолучитьИмяВременногоФайла("zip");

	КаталогРаспаковки = ПолучитьИмяВременногоФайла("");

	ВременныеПути = Новый Массив;

	ВременныеПути.Добавить(ИмяZip);

	ВременныеПути.Добавить(КаталогРаспаковки);

	

	Попытка

		

		АрхивДанных.Записать(ИмяZip);

		СоздатьКаталог(КаталогРаспаковки);

		

		Если НЕ ОбменДаннымиСервер.РаспаковатьZipФайл(ИмяZip, КаталогРаспаковки) Тогда

			ВызватьИсключение НСтр("ru = 'Не удалось распаковать ZIP-архив данных обмена.'");

		КонецЕсли;

		

		ИмяФайлаПравил = ОбщегоНазначенияКлиентСервер.ДобавитьКонецРазделителяПути(КаталогРаспаковки)

			+ ИмяФайлаПравилВАрхиве();

		ИмяФайлаДанных = ОбщегоНазначенияКлиентСервер.ДобавитьКонецРазделителяПути(КаталогРаспаковки)

			+ ИмяФайлаДанныхВАрхиве();

		

		ФайлПравил = Новый Файл(ИмяФайлаПравил);

		ФайлДанных = Новый Файл(ИмяФайлаДанных);

		

		Если НЕ ФайлПравил.Существует() Тогда

			ВызватьИсключение НСтр("ru = 'В архиве отсутствует файл правил обмена ExchangeRules.xml.'");

		КонецЕсли;

		

		Если НЕ ФайлДанных.Существует() Тогда

			ВызватьИсключение НСтр("ru = 'В архиве отсутствует файл данных обмена ExchangeData.xml.'");

		КонецЕсли;

		

		Движок = Обработки.рг_УниверсальныйОбменДаннымиXML.Создать();

		Движок.ИмяФайлаПравилОбмена = ИмяФайлаПравил;

		Движок.ИмяФайлаОбмена = ИмяФайлаДанных;

		Движок.ЗагрузитьПравилаОбмена();

		Движок.ОткрытьФайлЗагрузки();

		Движок.ВыполнитьЗагрузку();

		

		Если Движок.ФлагОшибки Тогда

			ВызватьИсключение НСтр("ru = 'Движок обмена завершил загрузку с ошибками.'");

		КонецЕсли;

		

	Исключение

		

		УдалитьВременныеФайлыИКаталоги(ВременныеПути);

		ВызватьИсключение;

		

	КонецПопытки;

	

	УдалитьВременныеФайлыИКаталоги(ВременныеПути);

	

КонецПроцедуры



Процедура УдалитьВременныеФайлыИКаталоги(Пути)

	

	Для Каждого Путь Из Пути Цикл

		

		Если ПустаяСтрока(Путь) Тогда

			Продолжить;

		КонецЕсли;

		

		УдалитьФайлы(Путь);

		

	КонецЦикла;

	

КонецПроцедуры



