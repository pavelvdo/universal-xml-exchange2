// Точка входа регламентного задания обмена по профилю-приёмнику.

//

// Параметры:

//   Профиль - СправочникСсылка.рг_НастройкиОбменаXML - профиль обмена.

//

Процедура ВыполнитьОбменПоПрофилю(Профиль) Экспорт

	

	Если НЕ ЗначениеЗаполнено(Профиль) Тогда

		

		ЗаписатьСобытиеОбмена(

			УровеньЖурналаРегистрации.Предупреждение,

			,

			НСтр("ru = 'Профиль не задан'"));

		Возврат;

		

	КонецЕсли;

	

	РезультатСеанса = ВыполнитьСеансОбменаПоПрофилюПриемника(Профиль);

	

	Если РезультатСеанса.Успех Тогда

		

		ЗаписатьСобытиеОбмена(

			УровеньЖурналаРегистрации.Информация,

			Профиль,

			НСтр("ru = 'Регламентный обмен по профилю выполнен успешно'"));

		

	Иначе

		

		ЗаписатьСобытиеОбмена(

			УровеньЖурналаРегистрации.Ошибка,

			Профиль,

			РезультатСеанса.СообщениеОбОшибке);

		

	КонецЕсли;

	

КонецПроцедуры



// Находит единственный профиль-источник по паре префиксов.

//

// Параметры:

//   Префикс - Строка - префикс базы-источника.

//   ПрефиксБазыПриемника - Строка - префикс базы-приёмника.

//

// Возвращаемое значение:

//   СправочникСсылка.рг_НастройкиОбменаXML - профиль-источник.

//

Функция НайтиЕдинственныйПрофильИсточникаПоПрефиксам(Префикс, ПрефиксБазыПриемника) Экспорт

	

	Запрос = Новый Запрос;

	Запрос.Текст =

	"ВЫБРАТЬ

	|	НастройкиОбменаXML.Ссылка КАК Ссылка

	|ИЗ

	|	Справочник.рг_НастройкиОбменаXML КАК НастройкиОбменаXML

	|ГДЕ

	|	НастройкиОбменаXML.Источник = ИСТИНА

	|	И НастройкиОбменаXML.Префикс = &Префикс

	|	И НастройкиОбменаXML.ПрефиксБазыПриемника = &ПрефиксБазыПриемника";

	

	Запрос.УстановитьПараметр("Префикс", Префикс);

	Запрос.УстановитьПараметр("ПрефиксБазыПриемника", ПрефиксБазыПриемника);

	

	Выборка = Запрос.Выполнить().Выбрать();

	

	Если НЕ Выборка.Следующий() Тогда

		

		ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(

			НСтр("ru = 'Профиль-источник не найден по префиксам ""%1"" / ""%2"".'"),

			Префикс,

			ПрефиксБазыПриемника);

		ЗаписатьСобытиеОбмена(УровеньЖурналаРегистрации.Ошибка, , ТекстОшибки);

		ВызватьИсключение ТекстОшибки;

		

	КонецЕсли;

	

	Профиль = Выборка.Ссылка;

	

	Если Выборка.Следующий() Тогда

		

		ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(

			НСтр("ru = 'Найдено более одного профиля-источника по префиксам ""%1"" / ""%2"".'"),

			Префикс,

			ПрефиксБазыПриемника);

		ЗаписатьСобытиеОбмена(УровеньЖурналаРегистрации.Ошибка, , ТекстОшибки);

		ВызватьИсключение ТекстОшибки;

		

	КонецЕсли;

	

	Возврат Профиль;

	

КонецФункции



// Формирует ZIP-пакет выгрузки для операции GetData.

//

// Параметры:

//   Префикс - Строка - префикс базы-источника.

//   ПрефиксБазыПриемника - Строка - префикс базы-приёмника.

//

// Возвращаемое значение:

//   ДвоичныеДанные - ZIP с XML правил и XML данных.

//

Функция ПолучитьДанныеОбмена(Префикс, ПрефиксБазыПриемника) Экспорт

	

	ПрофильИсточника = НайтиЕдинственныйПрофильИсточникаПоПрефиксам(Префикс, ПрефиксБазыПриемника);

	НачатьВыгрузкуGetData(ПрофильИсточника);

	

	Попытка

		

		Возврат ВыполнитьФазуВыгрузкиGetData(ПрофильИсточника);

		

	Исключение

		

		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());

		УстановитьСтатусПрофиляИсточника(

			ПрофильИсточника,

			СтатусОшибка(),

			ТекстОшибки);

		ЗаписатьСобытиеОбмена(

			УровеньЖурналаРегистрации.Ошибка,

			ПрофильИсточника,

			ТекстОшибки);

		ВызватьИсключение;

		

	КонецПопытки;

	

КонецФункции



// Подтверждает успешную загрузку данных на приёмнике.

//

// Параметры:

//   Префикс - Строка - префикс базы-источника.

//   ПрефиксБазыПриемника - Строка - префикс базы-приёмника.

//

// Возвращаемое значение:

//   Строка - признак успешного подтверждения.

//

Функция ПодтвердитьПолучениеДанных(Префикс, ПрефиксБазыПриемника) Экспорт

	

	ПрофильИсточника = НайтиЕдинственныйПрофильИсточникаПоПрефиксам(Префикс, ПрефиксБазыПриемника);

	ТекущийСтатус = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПрофильИсточника, "Статус");

	

	Если ТекущийСтатус = СтатусВыполнено() Тогда

		Возврат НСтр("ru = 'OK'");

	КонецЕсли;

	

	Если ТекущийСтатус <> СтатусВыполняется() Тогда

		

		ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(

			НСтр("ru = 'Подтверждение получения данных недоступно для статуса ""%1"".'"),

			ПредставлениеСтатуса(ТекущийСтатус));

		ЗаписатьСобытиеОбмена(УровеньЖурналаРегистрации.Ошибка, ПрофильИсточника, ТекстОшибки);

		ВызватьИсключение ТекстОшибки;

		

	КонецЕсли;

	

	УстановитьСтатусПрофиляИсточника(

		ПрофильИсточника,

		СтатусВыполнено(),

		НСтр("ru = 'Подтверждено получение данных на приёмнике'"));

	

	Возврат НСтр("ru = 'OK'");

	

КонецФункции



